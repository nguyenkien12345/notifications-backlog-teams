# Backlog Configuration
BACKLOG_SPACE_ID=your-space-id
BACKLOG_API_KEY=your-api-key
# Domain suffix: backlog.com, backlog.jp or a custom domain if self-hosted
BACKLOG_DOMAIN=backlog.com
ONLY_UNREAD=true

# Microsoft Teams Configuration
TEAMS_WEBHOOK_URL=https://your-space.webhook.office.com/webhookb2/...

# Discord Configuration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Bot Configuration
SYNC_INTERVAL_MINUTES=5
STATE_FILE_PATH=storage/state.json
LOG_LEVEL=INFO
